{
  "manifest_version": 2,
  "version": "3.3.0",
  "name": "QQ头像表情包 | Avatar Meme",
  "description": "输入QQ号或@某人，用其头像制作精神小伙、我太难了、暗中观察等搞笑表情包。",
  "author": {
    "name": "ling",
    "url": "https://github.com/ling"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/ling/maibot-avatar-meme",
    "homepage": "https://github.com/ling/maibot-avatar-meme",
    "documentation": "https://github.com/ling/maibot-avatar-meme",
    "issues": "https://github.com/ling/maibot-avatar-meme/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [],
  "capabilities": [
    "send.text",
    "send.image",
    "config.get"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": [
      "zh-CN"
    ]
  },
  "id": "ling.avatar-meme"
}
